[["Data Flow",null,null,null,null,null],["Data Flow หลักของระบบ",null,null,null,null,null],[null,null,null,null,null,null],["step","flow_name","trigger","process","tables_involved","important_rules"],[1,"Import DataOcean","Admin นำเข้าไฟล์ Excel","สร้าง import batch → Validate 19 columns → Upsert organizations → Upsert locations → เก็บ raw_data","location_import_batches, location_import_rows, organizations, locations","ห้ามลบสถานที่ที่หายจากไฟล์อัตโนมัติ; เปลี่ยน INACTIVE/ตรวจสอบ"],[2,"Safety Effort Check-in","ผู้ใช้เริ่ม Safety Effort และเลือกสถานที่","ขอสิทธิ์ GPS → เก็บ actual_position → Snapshot selected location → คำนวณระยะ → บันทึก checkins","users, locations, checkins","ต้องแจ้งผู้ใช้ว่าเก็บ GPS จริง; ไม่บล็อกเมื่อสถานที่ไม่ตรง"],[3,"Custom Location","ผู้ใช้เพิ่มสถานที่จากแผนที่","สร้าง locations source=USER, type=CUSTOM, created_by=user → เปิดใช้ร่วมกันทันที","users, locations","เก็บ Audit และมีสิทธิ์ Admin สำหรับแก้ไข/ระงับ"],[4,"Safety Activity","ดำเนินกิจกรรมหลัง Check-in","สร้าง safety_activity → ทำ assessment → บันทึก finding/action → Complete","checkins, safety_activities, assessment_*, safety_findings, corrective_actions","เก็บ Snapshot ของ Template version"],[5,"Earn Points","กิจกรรมผ่านเงื่อนไขคะแนน","อ่าน point_rule → สร้าง point_transaction ด้วย idempotency_key → อัปเดต point_balances","point_rules, point_transactions, point_balances","Ledger เป็น Source of truth ห้ามแก้ยอดโดยตรง"],[6,"Redeem Reward","ผู้ใช้แลกรางวัล","ตรวจ balance/stock → สร้าง redemption → ตัดคะแนน → บันทึก inventory transaction","rewards, reward_redemptions, point_transactions, reward_inventory_transactions","ทำใน Database transaction เดียวเพื่อป้องกันยอด/Stock ผิด"],["7","SSO Login → users","SSO callback สำเร็จ","ระบบ normalize claims แล้ว upsert users ด้วย sso_external_id/email","users","ไม่เก็บ access_token, id_token, refresh_token ลง database"],["8","Session API → Profile/Topbar","หน้าเว็บเรียก /api/auth/session","API อ่าน session cookie แล้วเติมข้อมูลล่าสุดจาก users","user