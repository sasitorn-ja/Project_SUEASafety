# Public app URL used to build SSO redirect URLs in production.
APP_BASE_URL=https://safety.cipcloud.net

# RMC SSO / OIDC provider.
SSO_ISSUER=https://rmc-sso.cipcloud.net
SSO_AUTHORIZE_URL=https://rmc-sso.cipcloud.net/api/auth/oauth2/authorize
SSO_TOKEN_URL=https://rmc-sso.cipcloud.net/api/auth/oauth2/token
SSO_USERINFO_URL=https://rmc-sso.cipcloud.net/api/auth/oauth2/userinfo
SSO_END_SESSION_URL=https://rmc-sso.cipcloud.net/api/auth/oauth2/endsession
SSO_REDIRECT_URI=https://safety.cipcloud.net/api/auth/callback/rmc-sso
SSO_POST_LOGOUT_REDIRECT_URI=https://safety.cipcloud.net/login
SSO_SCOPE=openid profile email offline_access

# Fill these from the SSO project metadata/MD.
SSO_CLIENT_ID=capc_safety
SSO_CLIENT_SECRET=

# client_secret_post is the default. Use client_secret_basic only if the SSO metadata says so.
SSO_TOKEN_AUTH_METHOD=client_secret_post

# Generate a long random value for production. Used to sign app session cookies.
APP_SESSION_SECRET=

# MySQL database for CPAC_Safety.
DATABASE_URL=mysql://cpac_safety_app:replace-with-password@192.168.1.196:3306/CPAC_Safety

# Read-only connection for rmc_sso.plant master sync.
# RMR_SSO_DATABASE_URL remains supported as a legacy alias.
RMC_SSO_DATABASE_URL=mysql://cpac_safety_reader:replace-with-password@192.168.1.196:3306/rmc_sso

# Media uploads. If Cloudinary is configured, files are stored in Cloudinary.
# If not configured, the app falls back to the Docker volume at /app/.data/uploads.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=cpac-safety
MAX_UPLOAD_BYTES=8388608

# Persistent upload directory mounted by the deployment environment.
UPLOAD_DIR=/var/lib/suea-safety/uploads

# Backward-compatible aliases are also supported by the application:
# RMC_SSO_ISSUER, RMC_SSO_CLIENT_ID, RMC_SSO_CLIENT_SECRET, RMC_SSO_REDIRECT_URI,
# RMC_SSO_POST_LOGOUT_REDIRECT_URI, RMC_SSO_SCOPE, RMC_SSO_TOKEN_AUTH_METHOD.

# OpenRouter API for the "Nong Wangjai" AI Safety Buddy.
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# Admin allowlist for Swagger/OpenAPI docs.
# Comma-separated values. Match by user id, SSO sub, email, or username.
